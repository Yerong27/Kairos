# Gemini
GEMINI_API_KEY=replace_with_your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-lite

# Notion public integration OAuth
NOTION_CLIENT_ID=replace_with_your_notion_client_id
NOTION_CLIENT_SECRET=replace_with_your_notion_client_secret
NOTION_REDIRECT_URI=http://localhost:8000/notion/callback

# Optional diagnostics
KAIROS_DISABLE_CACHE=false
KAIROS_DEBUG_DUMP=false
KAIROS_RUN_ID=local
