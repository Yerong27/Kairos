{
  "manifest_version": 3,
  "name": "Kairos Job Agent",
  "version": "0.3.0",
  "permissions": ["activeTab", "scripting", "storage", "tabs", "webNavigation"],
  "host_permissions": ["http://localhost:8000/*", "http://127.0.0.1:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Kairos Job Agent",
    "default_popup": "popup.html"
  }
}
